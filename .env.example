# LLM
ANTHROPIC_API_KEY=your_anthropic_api_key_here

#SLM
GROQ_API_KEY=your_groq_api_key_here

# LangSmith observability
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=agreements-management

# Specialist agent URLs (used by the planner)
CREATOR_AGENT_URL=http://localhost:8001
QUERY_AGENT_URL=http://localhost:8002
MODIFIER_AGENT_URL=http://localhost:8003

# Database
DATABASE_URL=sqlite+aiosqlite:///./agreements.db
